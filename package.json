{
  "name": "@crawlertoll/client",
  "version": "0.1.0",
  "description": "Buyer SDK for CrawlerToll — discover publishers, query MCP endpoints, verify signed attestation envelopes. Built for Claude Agent SDK developers.",
  "license": "Apache-2.0",
  "author": "Charthouse Ltd",
  "homepage": "https://crawlertoll.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nhrzxxw9dn-web/crawlertoll-sdk-js.git"
  },
  "bugs": {
    "url": "https://github.com/nhrzxxw9dn-web/crawlertoll-sdk-js/issues"
  },
  "keywords": [
    "crawlertoll",
    "ai-agents",
    "mcp",
    "claude-agent-sdk",
    "ai-licensing",
    "attestation",
    "ed25519"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./verify": {
      "import": "./dist/verify.js",
      "require": "./dist/verify.cjs",
      "types": "./dist/verify.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/verify.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.7.1",
    "canonicalize": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
